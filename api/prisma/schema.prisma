generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String             @id @default(cuid())
  username         String             @unique
  password         String
  role             String             @default("user")
  shopId           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  CommissionRecord CommissionRecord[]
  serialNumberLogs SerialNumberLog[]
  stockInOrders    StockInOrder[]
  stockInOrderLogs StockInOrderLog[]
  Stocktake        Stocktake[]
  StocktakeLog     StocktakeLog[]
  TransferLog      TransferLog[]
  TransferOrder    TransferOrder[]
  userRoles        UserRole[]
}

model Shop {
  id               String            @id @default(cuid())
  name             String
  address          String
  phone            String
  managerId        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  financialRecords FinancialRecord[]
  products         Product[]
  PurchaseOrder    PurchaseOrder[]
  PurchaseReturn   PurchaseReturn[]
  salesOrders      SalesOrder[]
  serialNumbers    SerialNumber[]
  stockInOrders    StockInOrder[]
  Stocktake        Stocktake[]
  suppliers        Supplier[]
  TransferOrder    TransferOrder[]
  Warehouse        Warehouse[]
}

model ProductVariant {
  id            String         @id @default(cuid())
  productId     String
  color         String
  capacity      String
  version       String
  price         Decimal
  costPrice     Decimal
  stock         Int
  sku           String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  serialNumbers SerialNumber[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  code      String     @unique
  parentId  String?
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  @@index([isActive, sortOrder, createdAt])
  @@index([parentId, isActive, sortOrder])
  @@index([name])
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  logo      String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([isActive, sortOrder, createdAt])
  @@index([name])
}

model Product {
  id                 String               @id @default(cuid())
  name               String
  categoryId         String?
  brandId            String?
  categoryLegacy     String?
  brandLegacy        String?
  model              String
  price              Decimal
  costPrice          Decimal
  shopId             String?
  warehouseId        String?
  minStock           Int?                 @default(10)
  alertLevel         String?
  alertEnabled       Boolean?             @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  inventoryLogs      InventoryLog[]
  warehouse          Warehouse?           @relation(fields: [warehouseId], references: [id])
  shop               Shop?                @relation(fields: [shopId], references: [id])
  brand              Brand?               @relation(fields: [brandId], references: [id])
  category           Category?            @relation(fields: [categoryId], references: [id])
  variants           ProductVariant[]
  PurchaseOrderItem  PurchaseOrderItem[]
  PurchaseReturnItem PurchaseReturnItem[]
  salesOrderItems    SalesOrderItem[]
  serialNumbers      SerialNumber[]
  stockInOrderItems  StockInOrderItem[]
  StocktakeItem      StocktakeItem[]
  TransferOrderItem  TransferOrderItem[]

  @@index([categoryId])
  @@index([brandId])
  @@index([shopId])
  @@index([name, model])
  @@index([createdAt])
}

model InventoryLog {
  id        String   @id @default(cuid())
  productId String
  quantity  Int
  type      String
  reason    String
  shopId    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SalesOrder {
  id               String             @id @default(cuid())
  shopId           String
  totalAmount      Decimal
  status           String             @default("completed")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  CommissionRecord CommissionRecord[]
  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items            SalesOrderItem[]
}

model SalesOrderItem {
  id            String         @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  price         Decimal
  createdAt     DateTime       @default(now())
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  order         SalesOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serialNumbers SerialNumber[]
}

model FinancialRecord {
  id          String   @id @default(cuid())
  shopId      String
  amount      Decimal
  type        String
  category    String
  description String
  createdAt   DateTime @default(now())
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  description     String?
  type            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model SerialNumber {
  id                   String              @id @default(cuid())
  serialNumber         String              @unique
  productId            String
  productVariantId     String?
  status               String              @default("in_stock")
  shopId               String
  warehouseId          String?
  purchaseOrderId      String?
  purchaseOrderItemId  String?
  purchaseReturnId     String?
  purchaseReturnItemId String?
  salesOrderId         String?
  salesOrderItemId     String?
  transferOrderId      String?
  transferOrderItemId  String?
  stocktakeId          String?
  stocktakeItemId      String?
  stockInOrderId       String?
  stockInOrderItemId   String?
  serviceTicketId      String?
  alertLevel           String?
  alertMessage         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  stockInOrderItem     StockInOrderItem?   @relation(fields: [stockInOrderItemId], references: [id])
  stocktakeItem        StocktakeItem?      @relation(fields: [stocktakeItemId], references: [id])
  transferOrderItem    TransferOrderItem?  @relation(fields: [transferOrderItemId], references: [id])
  salesOrderItem       SalesOrderItem?     @relation(fields: [salesOrderItemId], references: [id])
  purchaseReturnItem   PurchaseReturnItem? @relation(fields: [purchaseReturnItemId], references: [id])
  purchaseOrderItem    PurchaseOrderItem?  @relation(fields: [purchaseOrderItemId], references: [id])
  warehouse            Warehouse?          @relation(fields: [warehouseId], references: [id])
  shop                 Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productVariant       ProductVariant?     @relation(fields: [productVariantId], references: [id])
  product              Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  logs                 SerialNumberLog[]
}

model SerialNumberLog {
  id             String       @id @default(cuid())
  serialNumberId String
  oldStatus      String
  newStatus      String
  reason         String
  operatorId     String
  createdAt      DateTime     @default(now())
  operator       User         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  serialNumber   SerialNumber @relation(fields: [serialNumberId], references: [id], onDelete: Cascade)
}

model CommissionRule {
  id              String   @id @default(cuid())
  name            String
  type            String
  value           Decimal
  minAmount       Decimal?
  maxAmount       Decimal?
  productCategory String?
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CommissionRecord {
  id        String     @id @default(cuid())
  orderId   String
  userId    String
  amount    Decimal
  status    String     @default("pending")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Supplier {
  id              String          @id @default(cuid())
  name            String
  code            String          @unique
  address         String?
  phone           String?
  email           String?
  companyName     String?
  taxNumber       String?
  bankName        String?
  bankAccount     String?
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  contactPosition String?
  status          String          @default("active")
  notes           String?
  shopId          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseOrders  PurchaseOrder[]
  stockInOrders   StockInOrder[]
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([name])
  @@index([code])
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  shopId         String
  supplierId     String
  totalAmount    Decimal
  status         String              @default("pending")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  shop           Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items          PurchaseOrderItem[]
  PurchaseReturn PurchaseReturn[]
}

model PurchaseOrderItem {
  id            String         @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  price         Decimal
  createdAt     DateTime       @default(now())
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  order         PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serialNumbers SerialNumber[]
}

model PurchaseReturn {
  id          String               @id @default(cuid())
  orderId     String
  shopId      String
  reason      String
  totalAmount Decimal
  status      String               @default("pending")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  shop        Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order       PurchaseOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items       PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id            String         @id @default(cuid())
  returnId      String
  productId     String
  quantity      Int
  price         Decimal
  createdAt     DateTime       @default(now())
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  return        PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  serialNumbers SerialNumber[]
}

model Warehouse {
  id                 String          @id @default(cuid())
  name               String
  code               String          @unique
  address            String
  contactName        String
  contactPhone       String
  status             String          @default("active")
  shopId             String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  products           Product[]
  serialNumbers      SerialNumber[]
  stockInOrders      StockInOrder[]
  Stocktake          Stocktake[]
  transferOrdersTo   TransferOrder[] @relation("ToWarehouse")
  transferOrdersFrom TransferOrder[] @relation("FromWarehouse")
  shop               Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model TransferOrder {
  id              String              @id @default(cuid())
  fromWarehouseId String
  toWarehouseId   String
  shopId          String
  operatorId      String
  status          String              @default("pending")
  reason          String
  totalItems      Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  logs            TransferLog[]
  operator        User                @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  shop            Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  fromWarehouse   Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  items           TransferOrderItem[]
}

model TransferOrderItem {
  id            String         @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  createdAt     DateTime       @default(now())
  serialNumbers SerialNumber[]
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  order         TransferOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model TransferLog {
  id              String        @id @default(cuid())
  transferOrderId String
  oldStatus       String
  newStatus       String
  reason          String
  operatorId      String
  createdAt       DateTime      @default(now())
  operator        User          @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  transferOrder   TransferOrder @relation(fields: [transferOrderId], references: [id], onDelete: Cascade)
}

model Stocktake {
  id          String          @id @default(cuid())
  shopId      String
  warehouseId String
  operatorId  String
  status      String          @default("in_progress")
  startDate   DateTime        @default(now())
  endDate     DateTime?
  totalItems  Int
  variance    Decimal
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  operator    User            @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items       StocktakeItem[]
  logs        StocktakeLog[]
}

model StocktakeItem {
  id            String         @id @default(cuid())
  stocktakeId   String
  productId     String
  expectedStock Int
  actualStock   Int
  variance      Int
  unitPrice     Decimal
  varianceValue Decimal
  notes         String?
  createdAt     DateTime       @default(now())
  serialNumbers SerialNumber[]
  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocktake     Stocktake      @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
}

model StocktakeLog {
  id          String    @id @default(cuid())
  stocktakeId String
  oldStatus   String
  newStatus   String
  reason      String
  operatorId  String
  createdAt   DateTime  @default(now())
  operator    User      @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  stocktake   Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
}

model StockInOrder {
  id          String             @id @default(cuid())
  shopId      String
  supplierId  String?
  warehouseId String?
  operatorId  String
  status      String             @default("pending")
  totalItems  Int                @default(0)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  operator    User               @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  warehouse   Warehouse?         @relation(fields: [warehouseId], references: [id])
  supplier    Supplier?          @relation(fields: [supplierId], references: [id])
  shop        Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items       StockInOrderItem[]
  logs        StockInOrderLog[]
}

model StockInOrderItem {
  id               String         @id @default(cuid())
  orderId          String
  productId        String
  quantity         Int
  price            Decimal
  serialNumberType String
  createdAt        DateTime       @default(now())
  serialNumbers    SerialNumber[]
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  order            StockInOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StockInOrderLog {
  id         String       @id @default(cuid())
  orderId    String
  oldStatus  String
  newStatus  String
  reason     String
  operatorId String
  createdAt  DateTime     @default(now())
  operator   User         @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  order      StockInOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

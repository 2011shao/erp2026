{
  "name": "multi-shop-erp",
  "version": "1.0.0",
  "description": "多门店线下手机与3C产品ERP系统",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "ts-node-dev --respawn --transpile-only api/src/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p api/tsconfig.json",
    "preview": "vite preview",
    "db:generate": "prisma generate --schema api/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema api/prisma/schema.prisma",
    "db:push": "prisma db push --schema api/prisma/schema.prisma",
    "db:seed": "ts-node api/prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "@types/dotenv": "^6.1.1",
    "antd": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^17.4.2",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.356.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.10.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "prisma": "^5.11.0",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0"
  }
}
